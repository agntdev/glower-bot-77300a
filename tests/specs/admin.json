[
  {
    "name": "Admin — add and delete a service",
    "steps": [
      {
        "send": { "text": "/admin" },
        "expect": [{ "method": "sendMessage", "payload": { "text": "⚙️ Admin panel" } }]
      },
      {
        "send": { "callback": "admin:add_service" },
        "expect": [{ "method": "sendMessage", "payload": { "text": "What's the service name?" } }]
      },
      {
        "send": { "text": "Facial" },
        "expect": [{ "method": "sendMessage", "payload": { "text": "How long is this service in minutes? (e.g. 60)" } }]
      },
      {
        "send": { "text": "90" },
        "expect": [{ "method": "sendMessage", "payload": { "text": "What's the price label? (e.g. $50)" } }]
      },
      {
        "send": { "text": "$80" },
        "expect": [{ "method": "sendMessage", "payload": { "text": "Describe the service:" } }]
      },
      {
        "send": { "text": "Deep cleansing facial" },
        "expect": [{ "method": "sendMessage", "payload": { "text": "✅ Service added!\n\nName: Facial\nDuration: 90 min\nPrice: $80\nDescription: Deep cleansing facial" } }]
      },
      {
        "send": { "callback": "admin:manage_services" },
        "expect": [{ "method": "sendMessage", "payload": { "text": "📋 Your services:" } }]
      },
      {
        "send": { "callback": "admin:view_service:1" },
        "expect": [{ "method": "sendMessage", "payload": { "text": "📌 Facial\n\nDuration: 90 min\nPrice: $80\nDescription: Deep cleansing facial" } }]
      }
    ]
  },
  {
    "name": "Admin — manage portfolio items",
    "steps": [
      {
        "send": { "text": "/admin" },
        "expect": [{ "method": "sendMessage", "payload": { "text": "⚙️ Admin panel" } }]
      },
      {
        "send": { "callback": "admin:add_service" },
        "expect": [{ "method": "sendMessage", "payload": { "text": "What's the service name?" } }]
      },
      {
        "send": { "text": "Manicure" },
        "expect": [{ "method": "sendMessage", "payload": { "text": "How long is this service in minutes? (e.g. 60)" } }]
      },
      {
        "send": { "text": "60" },
        "expect": [{ "method": "sendMessage", "payload": { "text": "What's the price label? (e.g. $50)" } }]
      },
      {
        "send": { "text": "$40" },
        "expect": [{ "method": "sendMessage", "payload": { "text": "Describe the service:" } }]
      },
      {
        "send": { "text": "Classic manicure" },
        "expect": [{ "method": "sendMessage", "payload": { "text": "✅ Service added!\n\nName: Manicure\nDuration: 60 min\nPrice: $40\nDescription: Classic manicure" } }]
      },
      {
        "send": { "callback": "admin:add_portfolio" },
        "expect": [{ "method": "sendMessage", "payload": { "text": "Which service is this portfolio item for?" } }]
      },
      {
        "send": { "callback": "admin:set_portfolio_tag:Manicure" },
        "expect": [{ "method": "sendMessage", "payload": { "text": "Add a caption for this portfolio item:" } }]
      },
      {
        "send": { "text": "Classic red manicure" },
        "expect": [{ "method": "sendMessage", "payload": { "text": "✅ Portfolio item added!\n\nService: Manicure\nCaption: Classic red manicure" } }]
      },
      {
        "send": { "callback": "admin:manage_portfolio" },
        "expect": [{ "method": "sendMessage", "payload": { "text": "🖼️ Portfolio items:" } }]
      }
    ]
  },
  {
    "name": "Admin — respond to reviews",
    "steps": [
      {
        "send": { "callback": "reviews:submit" },
        "expect": [{ "method": "sendMessage", "payload": { "text": "How would you rate your experience?\n\nTap a star to rate:" } }]
      },
      {
        "send": { "callback": "review:rate:4" },
        "expect": [{ "method": "sendMessage", "payload": { "text": "Thanks! Tell us about your experience." } }]
      },
      {
        "send": { "text": "Great service!" },
        "expect": [{ "method": "sendMessage", "payload": { "text": "📋 Review preview:\n\nRating: ⭐⭐⭐⭐\nReview: Great service!\n\nSubmit this review?" } }]
      },
      {
        "send": { "callback": "review:submit:yes" },
        "expect": [{ "method": "editMessageText", "payload": { "text": "✅ Review submitted! Thanks for your feedback.\n\nRating: ⭐⭐⭐⭐\nReview: Great service!" } }]
      },
      {
        "send": { "text": "/admin" },
        "expect": [{ "method": "sendMessage", "payload": { "text": "⚙️ Admin panel" } }]
      },
      {
        "send": { "callback": "admin:respond_reviews" },
        "expect": [{ "method": "sendMessage", "payload": { "text": "⭐ Reviews to respond to:" } }]
      }
    ]
  }
]
