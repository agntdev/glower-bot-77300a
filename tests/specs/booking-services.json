[
  {
    "name": "Book Service — empty state when no services",
    "steps": [
      {
        "send": { "callback": "booking:services" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "No services available yet — check back soon!"
            }
          }
        ]
      }
    ]
  },
  {
    "name": "Book Service — shows service list after admin adds one",
    "steps": [
      {
        "send": { "text": "/admin" },
        "expect": [{ "method": "sendMessage", "payload": { "text": "⚙️ Admin panel" } }]
      },
      {
        "send": { "callback": "admin:add_service" },
        "expect": [{ "method": "sendMessage", "payload": { "text": "What's the service name?" } }]
      },
      {
        "send": { "text": "Gel Manicure" },
        "expect": [{ "method": "sendMessage", "payload": { "text": "How long is this service in minutes? (e.g. 60)" } }]
      },
      {
        "send": { "text": "60" },
        "expect": [{ "method": "sendMessage", "payload": { "text": "What's the price label? (e.g. $50)" } }]
      },
      {
        "send": { "text": "$45" },
        "expect": [{ "method": "sendMessage", "payload": { "text": "Describe the service:" } }]
      },
      {
        "send": { "text": "Classic gel manicure with long-lasting polish" },
        "expect": [{ "method": "sendMessage", "payload": { "text": "✅ Service added!\n\nName: Gel Manicure\nDuration: 60 min\nPrice: $45\nDescription: Classic gel manicure with long-lasting polish" } }]
      }
    ]
  }
]
